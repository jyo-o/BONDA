{
  "uid": "eigenda-operators",
  "title": "EigenDA Operators",
  "tags": ["eigenda", "bonda", "operators"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Total Operators",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
          "rawSql": "SELECT COUNT(DISTINCT operator_id) AS \"Total Operators\" FROM eigenda.operator_probes",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "Dead Operators (>=5 consecutive failures)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
          "rawSql": "SELECT COUNT(*) AS \"Dead Operators\" FROM (SELECT operator_id, COUNT(*) AS fail_count FROM (SELECT operator_id, success, ROW_NUMBER() OVER (PARTITION BY operator_id ORDER BY probe_time DESC) AS rn FROM eigenda.operator_probes) recent WHERE rn <= 5 AND NOT success GROUP BY operator_id HAVING COUNT(*) = 5) sub",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Chunks per Operator",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
          "rawSql": "SELECT ROUND(AVG(chunks_returned)::numeric, 0) AS \"Avg Chunks\" FROM eigenda.operator_probes WHERE success = true",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Per-Operator Stats",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Per-Operator Success Rate",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success_pct" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              },
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 80 },
                    { "color": "green", "value": 95 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "success_pct", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
          "rawSql": "SELECT operator_id, operator_socket, COUNT(*) AS total, COUNT(*) FILTER (WHERE success) AS ok, ROUND(COUNT(*) FILTER (WHERE success)::numeric / NULLIF(COUNT(*)::numeric, 0) * 100, 1) AS success_pct, ROUND(AVG(latency_ms) FILTER (WHERE success)::numeric, 0) AS avg_lat, ROUND(AVG(chunks_returned) FILTER (WHERE success)::numeric, 0) AS avg_chunks FROM eigenda.operator_probes GROUP BY operator_id, operator_socket ORDER BY success_pct ASC",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Probe History",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Top 10 Worst Operators - Probe Success Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "pointSize": 5,
            "showPoints": "auto",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "asc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "bonda-tsdb" },
          "rawSql": "WITH worst AS (SELECT operator_id FROM eigenda.operator_probes GROUP BY operator_id ORDER BY COUNT(*) FILTER (WHERE success)::float / NULLIF(COUNT(*)::float, 0) ASC LIMIT 10) SELECT time_bucket('1 hour', p.probe_time) AS time, p.operator_id, COUNT(*) FILTER (WHERE p.success)::float / NULLIF(COUNT(*)::float, 0) * 100 AS success_pct FROM eigenda.operator_probes p JOIN worst w ON p.operator_id = w.operator_id WHERE $__timeFilter(p.probe_time) GROUP BY time, p.operator_id ORDER BY time",
          "format": "table"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1
}
