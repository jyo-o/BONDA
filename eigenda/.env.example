# ── Core ──────────────────────────────────────────────
# TimescaleDB connection string
TIMESCALEDB_URL=postgres://bonda:bonda@localhost:5432/bonda?sslmode=disable

# Ethereum L1 RPC (required for relay registry + operator discovery)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# EigenDA DataAPI v2 base URL
DATAAPI_BASE_URL=https://dataapi.eigenda.xyz/api/v2

# EigenDA Directory contract address (mainnet)
EIGENDA_DIRECTORY=0x64AB2e9A86FA2E183CB6f01B2D4050c1c2dFAad4

# ── Worker toggles ────────────────────────────────────
COLLECTOR_ENABLED=true
RELAY_VERIFIER_ENABLED=true
OPERATOR_VERIFIER_ENABLED=true
REVERIFIER_ENABLED=true
WRITE_PROBER_ENABLED=false
STAKE_INDEXER_ENABLED=true
EJECTION_INDEXER_ENABLED=true
KZG_VERIFY_ENABLED=true

# ── Tuning ────────────────────────────────────────────
COLLECTOR_POLL_INTERVAL=3s
RELAY_VERIFIER_PARALLEL=10
REVERIFIER_INTERVAL=5m
WRITE_PROBER_INTERVAL=5m
STAKE_INDEXER_INTERVAL=1h
EJECTION_POLL_INTERVAL=12s

# ── Write prober (optional) ──────────────────────────
# eigenda-proxy handles KZG + signing + payment internally
EIGENDA_PROXY_URL=http://eigenda-proxy:3100
# Private key for blob dispersal signing (hex, no 0x prefix)
DISPERSER_PRIVATE_KEY=

# ── API / Metrics ────────────────────────────────────
API_LISTEN_ADDR=:8080
METRICS_LISTEN_ADDR=:9090
